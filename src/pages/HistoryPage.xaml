<Page
    x:Class="ScreenLookup.src.pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScreenLookup.src.pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:xControls="clr-namespace:ScreenLookup.src.controls"
    Title="History"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="DataGrid_Top" TargetType="{x:Type DataGridCell}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Top" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="Foreground" Value="Black" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{x:Null}" />
                    <Setter Property="BorderBrush" Value="{x:Null}" />
                </Trigger>
            </Style.Triggers>

        </Style>
    </Page.Resources>

    <Grid Margin="20,12,40,40">
        <Controls:DynamicScrollViewer>
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock
                    Margin="32,0,0,10"
                    FontSize="25"
                    FontWeight="SemiBold"
                    Text="History" />

                <Grid Margin="15" VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            MaxHeight="34.94"
                            Margin="0,0,3,0"
                            HorizontalAlignment="Left"
                            Orientation="Horizontal">
                            <Controls:Button
                                x:Name="PageDown"
                                Appearance="Transparent"
                                Click="PageDown_click"
                                Icon="{wpfui:SymbolIcon Symbol=chevronLeft12,
                                                        Filled=False}"
                                MouseOverBackground="#07000000"
                                ToolTip="Previous " />

                            <Controls:TextBlock
                                x:Name="PageNumber"
                                Margin="10,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="1/1" />

                            <Controls:Button
                                x:Name="PageUp"
                                Appearance="Transparent"
                                Click="PageUp_click"
                                Icon="{wpfui:SymbolIcon Symbol=chevronRight12,
                                                        Filled=False}"
                                MouseOverBackground="#07000000"
                                ToolTip="Next Page" />

                            <ComboBox
                                x:Name="maxRow"
                                MinHeight="0"
                                Margin="5,0,0,0"
                                Padding="10,4,10,7"
                                VerticalAlignment="Stretch"
                                SelectedIndex="0">
                                <ComboBoxItem Content="10/page" Tag="10" />
                                <ComboBoxItem Content="20/page" Tag="20" />
                                <ComboBoxItem Content="30/page" Tag="30" />
                                <ComboBoxItem Content="50/page" Tag="50" />
                            </ComboBox>

                            <Controls:AutoSuggestBox
                                x:Name="HistorySearchBox"
                                MinWidth="200"
                                MaxWidth="200"
                                Margin="5,0,0,0"
                                PlaceholderText="Search"
                                QuerySubmitted="HistorySearchBox_QuerySubmitted"
                                TextChanged="HistorySearchBox_TextChanged" />

                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            MaxHeight="34.94"
                            Margin="3,0,3,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Controls:Button
                                x:Name="Export"
                                Margin="0,0,0,0"
                                HorizontalAlignment="Right"
                                Appearance="Transparent"
                                Click="Export_click"
                                Icon="{wpfui:SymbolIcon Symbol=ArrowDown12,
                                                        Filled=False}"
                                MouseOverBackground="#07000000"
                                ToolTip="Export" />
                            <Controls:Button
                                x:Name="Delete"
                                Margin="5,0,0,0"
                                HorizontalAlignment="Right"
                                Appearance="Transparent"
                                Click="Clear_click"
                                Icon="{wpfui:SymbolIcon Symbol=Delete12,
                                                        Filled=False}"
                                MouseOverBackground="#07000000"
                                ToolTip="Delete All" />

                            <Controls:Button
                                x:Name="Refresh"
                                Margin="5,0,0,0"
                                HorizontalAlignment="Right"
                                Appearance="Transparent"
                                Click="Refresh_click"
                                Icon="{wpfui:SymbolIcon Symbol=ArrowClockwise12,
                                                        Filled=False}"
                                MouseOverBackground="#07000000"
                                ToolTip="Refresh" />
                        </StackPanel>
                    </Grid>

                    <Controls:Card
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="0,0,0,0">
                        <DataGrid
                            x:Name="dataGrid"
                            Margin="0,5,20,0"
                            VerticalAlignment="Stretch"
                            AutoGenerateColumns="False"
                            BorderThickness="0,0,0,0"
                            CellStyle="{StaticResource DataGrid_Top}"
                            EnableColumnVirtualization="True"
                            EnableRowVirtualization="True"
                            GridLinesVisibility="Horizontal"
                            IsReadOnly="True"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Visible"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.IsVirtualizingWhenGrouping="False"
                            VirtualizingPanel.VirtualizationMode="Recycling">

                            <DataGrid.VerticalGridLinesBrush>
                                <LinearGradientBrush MappingMode="Absolute" EndPoint="0,3">
                                    <GradientStop Offset="0.33" Color="#18FFFFFF" />
                                    <GradientStop Offset="1" Color="Transparent" />
                                </LinearGradientBrush>
                            </DataGrid.VerticalGridLinesBrush>
                            <DataGrid.HorizontalGridLinesBrush>
                                <LinearGradientBrush MappingMode="Absolute" EndPoint="0,3">
                                    <GradientStop Offset="0.33" Color="#18FFFFFF" />
                                    <GradientStop Offset="1" Color="#33000000" />
                                </LinearGradientBrush>
                            </DataGrid.HorizontalGridLinesBrush>
                            <DataGrid.BorderBrush>
                                <LinearGradientBrush MappingMode="Absolute" EndPoint="0,3">
                                    <GradientStop Offset="0.33" Color="#18FFFFFF" />
                                    <GradientStop Offset="1" Color="Transparent" />
                                </LinearGradientBrush>
                            </DataGrid.BorderBrush>

                            <DataGrid.Columns>
                                <!--  Original words paragraph  -->
                                <DataGridTemplateColumn Width="*" Header="Original">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <Controls:Button
                                                        Width="20"
                                                        Height="20"
                                                        Padding="0"
                                                        VerticalAlignment="Top"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Click="Button_ParagraphTTS"
                                                        Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                                                Filled=False}"
                                                        Tag="{Binding SourceLanguage}"
                                                        ToolTip="{Binding Original}" />
                                                    <Controls:Button
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,2,0,0"
                                                        Padding="0"
                                                        VerticalAlignment="Top"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Click="Button_ParagraphCopy"
                                                        Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                                                Filled=False}"
                                                        Tag="{Binding Original}"
                                                        ToolTip="Copy" />

                                                    <Controls:ToggleSwitch
                                                        Margin="2,2,0,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Click="ToggleHistoryWords"
                                                        ToolTip="Show words">
                                                        <Controls:ToggleSwitch.LayoutTransform>
                                                            <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5" />
                                                        </Controls:ToggleSwitch.LayoutTransform>
                                                        <Controls:ToggleSwitch.RenderTransform>
                                                            <ScaleTransform ScaleX=".7" ScaleY=".7" />
                                                        </Controls:ToggleSwitch.RenderTransform>
                                                    </Controls:ToggleSwitch>
                                                </StackPanel>

                                                <ItemsControl
                                                    x:Name="originalWords"
                                                    Grid.Column="1"
                                                    Margin="15,0,0,0"
                                                    ItemsSource="{Binding OriginalWords}"
                                                    Visibility="Collapsed">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Controls:Button
                                                                Width="{Binding Width}"
                                                                Height="{Binding Height}"
                                                                Margin="0"
                                                                Padding="1.7,0,1.7,0"
                                                                HorizontalAlignment="Left"
                                                                BorderThickness="{Binding Border}"
                                                                Click="Button_Word"
                                                                Content="{Binding Word}"
                                                                Tag="{Binding TargetLanguage}"
                                                                ToolTip="{Binding SourceLanguage}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Controls:TextBlock
                                                    x:Name="original"
                                                    Grid.Column="1"
                                                    Margin="15,0,0,0"
                                                    Text="{Binding Original}"
                                                    TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--  Translated paragraph  -->
                                <DataGridTemplateColumn Width="*" Header="Translated">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <Controls:Button
                                                        Width="20"
                                                        Height="20"
                                                        Padding="0"
                                                        VerticalAlignment="Top"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Click="Button_ParagraphTTS"
                                                        Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                                                Filled=False}"
                                                        Tag="{Binding TargetLanguage}"
                                                        ToolTip="{Binding Translated}" />
                                                    <Controls:Button
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,2,0,0"
                                                        Padding="0"
                                                        VerticalAlignment="Top"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Click="Button_ParagraphCopy"
                                                        Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                                                Filled=False}"
                                                        Tag="{Binding Translated}"
                                                        ToolTip="Copy" />
                                                </StackPanel>
                                                <Controls:TextBlock
                                                    Grid.Column="1"
                                                    Margin="15,0,0,0"
                                                    Text="{Binding Translated}"
                                                    TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--  Delete button  -->
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Controls:Button
                                                    Margin="5,0,0,0"
                                                    Appearance="Transparent"
                                                    Click="Delete_click"
                                                    Icon="{wpfui:SymbolIcon Symbol=Dismiss24,
                                                                            Filled=False}"
                                                    MouseOverBackground="#07000000"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Delete" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Controls:Card>

                    <Controls:Flyout
                        x:Name="flayOut"
                        Padding="0"
                        Placement="Top">
                        <Controls:Flyout.RenderTransform>
                            <MatrixTransform x:Name="mt" />
                        </Controls:Flyout.RenderTransform>
                        <StackPanel>
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Controls:Button
                                    x:Name="flayoutOriginalTSS"
                                    Width="20"
                                    Height="20"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="Button_WordOriginalTTS"
                                    Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                            Filled=False}" />
                                <Controls:Button
                                    Grid.Column="0"
                                    Width="{Binding Width, ElementName=flayoutOriginalTSS}"
                                    Height="{Binding Height, ElementName=flayoutOriginalTSS}"
                                    Margin="2,0,0,0"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="Button_ParagraphCopy"
                                    Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                            Filled=False}"
                                    Tag="{Binding Text, ElementName=definitionOriginal}"
                                    ToolTip="Copy" />
                                <Controls:TextBlock
                                    x:Name="definitionOriginal"
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="definitionOriginal" />
                            </StackPanel>
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Controls:Button
                                    x:Name="flayoutTranslatedTSS"
                                    Width="20"
                                    Height="20"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="Button_WordTranslatedTTS"
                                    Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                            Filled=False}" />
                                <Controls:Button
                                    Grid.Column="0"
                                    Width="{Binding Width, ElementName=flayoutTranslatedTSS}"
                                    Height="{Binding Height, ElementName=flayoutTranslatedTSS}"
                                    Margin="2,0,0,0"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="Button_ParagraphCopy"
                                    Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                            Filled=False}"
                                    Tag="{Binding Text, ElementName=definitionTranslated}"
                                    ToolTip="Copy" />
                                <Controls:TextBlock
                                    x:Name="definitionTranslated"
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                                <xControls:LoadingSpiner
                                    x:Name="definitionTranslatedLoading"
                                    Width="20"
                                    Height="20" />
                            </StackPanel>
                            <Controls:Card
                                Margin="0,10,0,0"
                                Padding="5"
                                BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Controls:Button
                                        x:Name="openBrowser"
                                        Width="20"
                                        Height="20"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Click="Button_OpenBrowser"
                                        Icon="{wpfui:SymbolIcon Symbol=Globe24,
                                                                Filled=False}" />
                                    <Controls:Button
                                        x:Name="wordSave"
                                        Width="20"
                                        Height="20"
                                        Margin="2,0,0,0"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Click="Button_WordSave"
                                        Icon="{wpfui:SymbolIcon Symbol=Star24,
                                                                Filled=False}" />
                                </StackPanel>
                            </Controls:Card>
                        </StackPanel>
                    </Controls:Flyout>
                </Grid>

            </StackPanel>
        </Controls:DynamicScrollViewer>
    </Grid>
</Page>
