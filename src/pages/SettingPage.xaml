<Page xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
      x:Class="ScreenLookup.src.pages.SettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ScreenLookup.src.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingPage">

    <Grid>
        <Controls:DynamicScrollViewer Padding="24,14,24,0">
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Text="Source Languge" Margin="6"/>
                        <ComboBox
                            Width="135"
                            Grid.Column="1" SelectedIndex="0"
                            >
                            <ComboBoxItem Content="en"/>
                            <ComboBoxItem Content="th"/>
                            <ComboBoxItem Content="fr"/>
                            <ComboBoxItem Content="cn"/>
                            <ComboBoxItem Content="tw"/>
                            <ComboBoxItem Content="mx"/>
                        </ComboBox>
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Text="Target Languge" Margin="6"/>
                        <ComboBox
                            Width="135"
                            Grid.Column="1" SelectedIndex="1"
                            >
                            <ComboBoxItem Content="en"/>
                            <ComboBoxItem Content="th"/>
                            <ComboBoxItem Content="fr"/>
                            <ComboBoxItem Content="cn"/>
                            <ComboBoxItem Content="tw"/>
                            <ComboBoxItem Content="mx"/>
                        </ComboBox>
                    </Grid>
                </Controls:Card>
                
                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Text="Translation Service" Margin="6"/>
                        <ComboBox
                            Width="135"
                            Grid.Column="1" SelectedIndex="0"
                            >
                            <ComboBoxItem Content="Google"/>
                            <ComboBoxItem Content="Google New"/>
                            <ComboBoxItem Content="Bing"/>
                            <ComboBoxItem Content="Microsoft Azure"/>
                            <ComboBoxItem Content="Yandex"/>
                        </ComboBox>
                    </Grid>
                </Controls:Card>
                
                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Text="Capture Shortcut" Margin="6"/>
                        <Controls:TextBox Grid.Column="1" Text="Alt+Z" />
                    </Grid>
                </Controls:Card>
            </StackPanel>
        </Controls:DynamicScrollViewer>
    </Grid>
</Page>
