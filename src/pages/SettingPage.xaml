<Page
    x:Class="ScreenLookup.src.pages.SettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScreenLookup.src.pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:xControls="clr-namespace:ScreenLookup.src.controls"
    Title="Setting"
    mc:Ignorable="d">

    <Grid Margin="20,12,40,40">
        <Controls:DynamicScrollViewer>
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock
                    Margin="32,0,0,10"
                    FontSize="25"
                    FontWeight="SemiBold"
                    Text="Settings" />

                <TextBlock
                    Margin="5,0,0,5"
                    FontWeight="SemiBold"
                    Text="General" />

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Source Language" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Controls:Button
                                x:Name="downloadTesseract"
                                Margin="0,0,5,0"
                                Click="DownloadTesseractButton_Click">
                                <StackPanel>
                                    <xControls:LoadingSpiner x:Name="tesseractLoadingIcon" Width="12" />
                                    <Controls:SymbolIcon
                                        x:Name="tesseractLoadIcon"
                                        Filled="True"
                                        Symbol="ArrowDownload24" />
                                </StackPanel>
                            </Controls:Button>
                            <ComboBox
                                x:Name="sourceLanguageAccuracy"
                                Grid.Column="1"
                                Width="110"
                                SelectedIndex="{Binding SourceLanguageAccuracy}" />
                            <ComboBox
                                x:Name="sourceLanguage"
                                Grid.Column="1"
                                Width="200"
                                Margin="5,0,0,0"
                                SelectedIndex="{Binding SourceLanguage}" />
                        </StackPanel>
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Source Language Correction (Hunspell)" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Controls:Button
                                x:Name="downloadHunspell"
                                Margin="0,0,5,0"
                                Click="DownloadHunspellButton_Click">
                                <StackPanel>
                                    <xControls:LoadingSpiner x:Name="hunspellLoadingIcon" Width="12" />
                                    <Controls:SymbolIcon
                                        x:Name="hunspellLoadIcon"
                                        Filled="True"
                                        Symbol="ArrowDownload24" />
                                </StackPanel>
                            </Controls:Button>
                            <CheckBox IsChecked="{Binding HunSpell}" />
                        </StackPanel>
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Target Language" />
                        <ComboBox
                            x:Name="targetLanguage"
                            Grid.Column="1"
                            Width="200"
                            SelectedIndex="{Binding TargetLanguage}" />
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Translation Provider" />
                        <ComboBox
                            x:Name="translationProvider"
                            Grid.Column="1"
                            Width="200"
                            SelectedIndex="{Binding TranslationProvider}" />
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Text-To-Speech Provider" />
                        <ComboBox
                            x:Name="ttsProvider"
                            Grid.Column="1"
                            Width="200"
                            SelectedIndex="{Binding TTSProvider}" />
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Startup With Windows" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding StartupWithWindows}" />
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Start In Background" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding StartInBackground}" />
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Minimize To Tray" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding MinimizeToTray}" />
                    </Grid>
                </Controls:Card>

                <TextBlock
                    Margin="5,0,0,5"
                    FontWeight="SemiBold"
                    Text="Lookup" />

                <Controls:Card Margin="0,0,0,4" Padding="14,14,14,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock
                            Margin="6"
                            VerticalAlignment="Center"
                            Text="Lookup Shortcut" />
                        <xControls:ShortcutControl
                            x:Name="captureShortcut"
                            Grid.Column="1"
                            KeySetChanged="ShortcutControl_KeySetChanged" />
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Show Capture Image" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowImage}" />
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Close When Lost Focus" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding CloseLostFocus}" />
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Font" />
                        <ComboBox
                            Grid.Column="1"
                            Width="200"
                            FontFamily="{Binding FontFace}"
                            IsEditable="True"
                            ItemsSource="{Binding Source={x:Static Member=Fonts.SystemFontFamilies}}"
                            Text="{Binding FontFace}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Source}" FontFamily="{Binding .}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Controls:Card>

                <Controls:Card Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Controls:TextBlock Margin="6" Text="Font Size" />
                        <Controls:NumberBox
                            Grid.Column="1"
                            Width="200"
                            Maximum="100"
                            Minimum="10"
                            Value="{Binding FontSizeS, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Controls:Card>

                <TextBlock
                    Margin="5,0,0,5"
                    FontWeight="SemiBold"
                    Text="Reset" />

                <Controls:Card Margin="0,0,0,4">
                    <Controls:Button
                        Margin="5,0,0,0"
                        HorizontalAlignment="Left"
                        Click="ResetButton"
                        Icon="{wpfui:SymbolIcon Symbol=ArrowCounterclockwise24,
                                                Filled=False}"
                        ToolTip="Reset" />
                </Controls:Card>

            </StackPanel>
        </Controls:DynamicScrollViewer>
    </Grid>
</Page>
