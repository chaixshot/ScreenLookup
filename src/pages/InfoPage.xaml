<Page
    x:Class="ScreenLookup.src.pages.InfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScreenLookup.src.pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Info"
    mc:Ignorable="d">

    <Grid Margin="20,12,40,40">
        <Controls:DynamicScrollViewer>
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock
                    Margin="32,0,0,10"
                    FontSize="25"
                    FontWeight="SemiBold"
                    Text="About" />
                <TextBlock
                    x:Name="VersionTextblock"
                    Margin="5,0,0,5"
                    FontWeight="SemiBold"
                    Text="Version X.X" />
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Controls:Card />

                    <Controls:Card Grid.Row="1" />

                    <Controls:Card Grid.Row="2" />
                </Grid>
            </StackPanel>
        </Controls:DynamicScrollViewer>
    </Grid>
</Page>
