<Page x:Class="ScreenLookup.src.pages.InfoPage"
      xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ScreenLookup.src.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InfoPage">

    <Grid Margin="20,12,40,40">
        <Controls:DynamicScrollViewer>
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock Text="About" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />

                
            </StackPanel>
        </Controls:DynamicScrollViewer>
    </Grid>
</Page>
