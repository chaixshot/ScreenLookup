<UserControl
    x:Class="ScreenLookup.src.controls.TranslatedBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScreenLookup.src.controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d">

    <Controls:DynamicScrollViewer
        x:Name="translatedScrollViewer"
        IsScrollingVertically="True"
        VerticalScrollBarVisibility="Visible">

        <WrapPanel Orientation="Horizontal">
            <Controls:TextBlock
                x:Name="TranslatedText"
                Margin="2,2,10,2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{Binding FontFace}"
                FontSize="{Binding FontSizeS}"
                TextWrapping="Wrap" />

            <wpfui:ProgressRing
                x:Name="Loading"
                Width="12"
                Height="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"
                IsIndeterminate="True" />

            <Controls:Button
                x:Name="Refresh"
                Width="{Binding Width, ElementName=flayoutOriginalTSS}"
                Height="{Binding Height, ElementName=flayoutOriginalTSS}"
                Padding="0"
                VerticalAlignment="Top"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="Refresh_Click"
                Icon="{wpfui:SymbolIcon Symbol=ArrowClockwise24,
                                        Filled=False}"
                ToolTip="Refresh" />
        </WrapPanel>
    </Controls:DynamicScrollViewer>
</UserControl>
