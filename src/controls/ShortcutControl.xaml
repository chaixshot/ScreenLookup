<UserControl 
    x:Class="ScreenLookup.src.controls.ShortcutControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:ScreenLookup.src.controls"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="ShortcutUserControl"
    Margin="0,0,0,0"
    d:DataContext="{d:DesignInstance Type=local:ShortcutControl}"
    PreviewKeyDown="ShortcutControl_PreviewKeyDown"
    PreviewKeyUp="ShortcutControl_PreviewKeyUp"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="TextBodyNormal" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style x:Key="TextHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </UserControl.Resources>
    <Border>
        <StackPanel HorizontalAlignment="Left" Orientation="Vertical">
            <StackPanel
                x:Name="ButtonsPanel"
                Margin="0,8,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <ui:Button
                    x:Name="WinKey"
                    Width="24"
                    Height="24"
                    Margin="1,0"
                    CornerRadius="5" Padding="0">
                        <Image
                            x:Name="WinSymImage"
                            Width="10"
                            Height="10"
                            Stretch="Uniform" Source="/src/images/WinSym.png" />
                </ui:Button>
                <ui:Button
                    x:Name="CtrlKey"
                    Width="46"
                    Height="24"
                    Padding="0"
                    Margin="1,0"
                    CornerRadius="5">
                        <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Medium"
                        Foreground="Black"
                        Text="Ctrl" />
                </ui:Button>
                <ui:Button
                    x:Name="ShiftKey"
                    Width="70"
                    Height="24"
                    Padding="0"
                    Margin="1,0"
                    CornerRadius="5">
                        <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Medium"
                        Foreground="Black"
                        Text="Shift" />
                </ui:Button>
                <ui:Button
                    x:Name="AltKey"
                    Width="46"
                    Height="24"
                    Padding="0"
                    Margin="1,0"
                    CornerRadius="5">
                        <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Medium"
                        Foreground="Black"
                        Text="Alt" />
                </ui:Button>
                <ui:Button
                    x:Name="KeyKey"
                    Height="24"
                    MinWidth="24"
                    Padding="0"
                    Margin="1,0"
                    CornerRadius="5"
                    Visibility="Visible">
                    <TextBlock
                        x:Name="KeyLetterTextBlock"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Medium"
                        Foreground="Black"
                        Text="X" />
                </ui:Button>

                <ToggleButton x:Name="RecordingToggleButton" Click="RecordingToggleButton_Click" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Record24" />
                        <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Text="Record" />
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
            <TextBlock
                x:Name="ErrorText"
                d:Text="error message"
                Style="{StaticResource TextBodyNormal}" HorizontalAlignment="Right" />

        </StackPanel>
    </Border>
</UserControl>
