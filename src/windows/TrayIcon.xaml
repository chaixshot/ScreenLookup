<Window
    x:Class="ScreenLookup.src.windows.TrayIcon"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScreenLookup.src.windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
    Title="TrayIcon"
    Width="0"
    Height="0"
    Background="Transparent"
    IsHitTestVisible="False"
    Left="-50"
    Opacity="0"
    RenderOptions.ClearTypeHint="Enabled"
    ShowInTaskbar="True"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="ClearType"
    Top="-50"
    WindowStyle="ToolWindow"
    mc:Ignorable="d">
    <tray:NotifyIcon
        x:Name="NotifyIcon"
        FocusOnLeftClick="False"
        Icon="/src/images/applicationIcon.ico"
        LeftClick="Tray_LeftClick"
        TooltipText="ScreenLookup">
        <tray:NotifyIcon.Menu>
            <ContextMenu>
                <MenuItem Click="TrayItemSettings_Click" Header="Settings">
                    <MenuItem.Icon>
                        <Controls:SymbolIcon Symbol="Settings24" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Click="TrayItemHistory_Click" Header="History">
                    <MenuItem.Icon>
                        <Controls:SymbolIcon Symbol="History24" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Click="TrayItemSaved_Click" Header="Saved">
                    <MenuItem.Icon>
                        <Controls:SymbolIcon Symbol="Star24" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="trayCapture"
                    Click="TrayItemCapture_Click"
                    Header="Lookup">
                    <MenuItem.Icon>
                        <Controls:SymbolIcon Symbol="Screenshot20" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Click="TrayItemExit_Click" Header="Close">
                    <MenuItem.Icon>
                        <Controls:SymbolIcon Symbol="Dismiss24" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </tray:NotifyIcon.Menu>
    </tray:NotifyIcon>
</Window>
