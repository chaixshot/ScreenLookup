<Controls:FluentWindow
    x:Class="ScreenLookup.src.windows.CaptureWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScreenLookup.src.windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:xControls="clr-namespace:ScreenLookup.src.controls"
    x:Name="captureWindow"
    Title="Capture"
    MinHeight="0"
    Background="Transparent"
    Deactivated="App_Deactivated"
    ExtendsContentIntoTitleBar="True"
    RenderOptions.ClearTypeHint="Enabled"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="ClearType"
    Topmost="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid Margin="10,5,10,5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <xControls:WordFlyout x:Name="flayOut" Tag="CaptureWindow" />

            <Grid x:Name="configMenu" Grid.Row="1">
                <wpfui:DynamicScrollViewer Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="sourceLanguageConfig" SelectionChanged="SourceLanguageConfig_SelectionChanged" />

                            <Controls:SymbolIcon Grid.Column="1" Symbol="ChevronRight24" />

                            <ComboBox
                                x:Name="targetLanguageConfig"
                                Grid.Column="2"
                                SelectionChanged="TargetLanguageConfig_SelectionChanged" />
                        </Grid>

                        <Controls:Card Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Controls:TextBlock Text="Source Language Correction (Hunspell)" />

                                <Controls:ToggleSwitch
                                    x:Name="hunSpell"
                                    Grid.Column="1"
                                    Click="ConfigSwitch_Toggle"
                                    IsChecked="{Binding HunSpell}" />
                            </Grid>
                        </Controls:Card>

                        <Controls:Card Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Controls:TextBlock Text="Show Capture Image" />

                                <Controls:ToggleSwitch
                                    x:Name="showImage"
                                    Grid.Column="1"
                                    Click="ConfigSwitch_Toggle"
                                    IsChecked="{Binding ShowImage}" />
                            </Grid>
                        </Controls:Card>

                        <Controls:Button Click="ConfigSubmit_Click" Content="Submit" />
                    </StackPanel>
                </wpfui:DynamicScrollViewer>
            </Grid>

            <Controls:Card
                x:Name="captureCard"
                Grid.Row="2"
                Padding="0">
                <Grid>
                    <StackPanel
                        x:Name="captureCardButton"
                        Margin="14,16,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">

                        <Controls:Button
                            Width="{Binding Width, ElementName=originalTTS}"
                            Height="{Binding Height, ElementName=originalTTS}"
                            Padding="0"
                            VerticalAlignment="Top"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="Button_OriginalTTS"
                            Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                    Filled=False}"
                            ToolTip="Speak" />

                        <Controls:Button
                            Width="{Binding Width, ElementName=originalTTS}"
                            Height="{Binding Height, ElementName=originalTTS}"
                            Margin="2,0,0,0"
                            Padding="0"
                            VerticalAlignment="Top"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="Button_Copy"
                            Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                    Filled=False}"
                            Tag="{Binding Text, ElementName=ocrText}"
                            ToolTip="Copy" />
                    </StackPanel>

                    <Controls:Image
                        x:Name="captureImage"
                        Source="/src/images/applicationIcon.ico"
                        Stretch="Uniform" />

                    <ItemsControl
                        Name="AltoText"
                        Width="{Binding Width, ElementName=captureImage}"
                        Height="{Binding Height, ElementName=captureImage}"
                        MinWidth="{Binding MinWidth, ElementName=captureImage}"
                        MinHeight="{Binding MinHeight, ElementName=captureImage}"
                        MaxWidth="{Binding MaxWidth, ElementName=captureImage}"
                        MaxHeight="{Binding MaxHeight, ElementName=captureImage}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Controls:Button
                                    Width="{Binding Width}"
                                    Height="{Binding Height}"
                                    Padding="0"
                                    Background="{wpfui:ThemeResource SystemAccentColorPrimaryBrush}"
                                    Click="Button_Word"
                                    Opacity="0.15"
                                    Tag="{Binding SourceLanguage}"
                                    ToolTip="{Binding Word}" />

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>

                    <wpfui:CardExpander
                        x:Name="imageTranslatedCard"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{wpfui:ThemeResource ApplicationBackgroundBrush}"
                        BorderBrush="{wpfui:ThemeResource ControlElevationBorderBrush}"
                        ContentPadding="0"
                        CornerRadius="0,0,0,8"
                        Header="Translated">

                        <Border
                            Padding="14,16,14,16"
                            Background="{wpfui:ThemeResource ApplicationBackgroundBrush}"
                            CornerRadius="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Controls:Button
                                    Width="{Binding Width, ElementName=translatedTSS}"
                                    Height="{Binding Height, ElementName=translatedTSS}"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="Button_TranslatedTTS"
                                    Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                            Filled=False}"
                                    ToolTip="Speak" />

                                <Controls:Button
                                    Grid.Column="1"
                                    Width="{Binding Width, ElementName=translatedTSS}"
                                    Height="{Binding Height, ElementName=translatedTSS}"
                                    Margin="2,0,0,0"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="Button_Copy"
                                    Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                            Filled=False}"
                                    Tag="{Binding Text, ElementName=translatedText}"
                                    ToolTip="Copy" />

                                <Controls:DynamicScrollViewer
                                    x:Name="imageTranslatedScrollViewer"
                                    Grid.Column="2"
                                    IsScrollingVertically="True"
                                    VerticalScrollBarVisibility="Visible">

                                    <WrapPanel Margin="5,0,0,0" Orientation="Horizontal">
                                        <wpfui:ProgressRing
                                            x:Name="imageTranslatedTextLoading"
                                            Width="12"
                                            Height="12"
                                            Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"
                                            IsIndeterminate="True" />

                                        <Controls:TextBlock x:Name="imageTranslatedText" TextWrapping="Wrap" />
                                    </WrapPanel>
                                </Controls:DynamicScrollViewer>
                            </Grid>
                        </Border>
                    </wpfui:CardExpander>
                </Grid>
            </Controls:Card>

            <Controls:Card
                x:Name="ocrCard"
                Grid.Row="3"
                Margin="0,3,0,0">
                <Controls:TextBlock
                    x:Name="ocrText"
                    Margin="45,0,0,0"
                    Text="ocrText"
                    TextWrapping="Wrap" />
            </Controls:Card>

            <Controls:Card
                x:Name="originalCard"
                Grid.Row="4"
                Margin="0,3,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Controls:Button
                        x:Name="originalTTS"
                        Width="20"
                        Height="20"
                        Padding="0"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_OriginalTTS"
                        Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                Filled=False}"
                        ToolTip="Speak" />

                    <Controls:Button
                        Grid.Column="1"
                        Width="{Binding Width, ElementName=originalTTS}"
                        Height="{Binding Height, ElementName=originalTTS}"
                        Margin="2,0,0,0"
                        Padding="0"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_Copy"
                        Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                Filled=False}"
                        Tag="{Binding Text, ElementName=ocrText}"
                        ToolTip="Copy" />

                    <Controls:DynamicScrollViewer
                        x:Name="originalScrollView"
                        Grid.Column="2"
                        IsScrollingVertically="True"
                        VerticalScrollBarVisibility="Visible">
                        <Grid Margin="5,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <wpfui:ProgressRing
                                x:Name="originalWordsLoading"
                                Width="12"
                                Height="12"
                                Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"
                                IsIndeterminate="True" />

                            <StackPanel Grid.Column="1">
                                <ItemsControl Name="originalWords">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Controls:Button
                                                Width="{Binding Width}"
                                                Height="{Binding Height}"
                                                Margin="0"
                                                Padding="{Binding Padding}"
                                                HorizontalAlignment="Left"
                                                Background="{wpfui:ThemeResource CardBackgroundFillColorDefault}"
                                                BorderThickness="{Binding Border}"
                                                Click="Button_Word"
                                                Tag="{Binding SourceLanguage}"
                                                ToolTip="{Binding Word}">

                                                <Controls:Button.Content>
                                                    <wpfui:TextBlock
                                                        FontFamily="{Binding FontFace}"
                                                        FontSize="{Binding FontSizeS, Mode=OneWay}"
                                                        Text="{Binding Word}" />
                                                </Controls:Button.Content>
                                            </Controls:Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Controls:DynamicScrollViewer>
                </Grid>
            </Controls:Card>

            <Controls:Card
                x:Name="translatedCard"
                Grid.Row="5"
                Margin="0,3,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Controls:Button
                        x:Name="translatedTSS"
                        Width="20"
                        Height="20"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_TranslatedTTS"
                        Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                Filled=False}"
                        ToolTip="Speak" />

                    <Controls:Button
                        Grid.Column="1"
                        Width="{Binding Width, ElementName=translatedTSS}"
                        Height="{Binding Height, ElementName=translatedTSS}"
                        Margin="2,0,0,0"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_Copy"
                        Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                Filled=False}"
                        Tag="{Binding Text, ElementName=translatedText}"
                        ToolTip="Copy" />

                    <Controls:DynamicScrollViewer
                        x:Name="translatedScrollViewer"
                        Grid.Column="2"
                        IsScrollingVertically="True"
                        VerticalScrollBarVisibility="Visible">
                        <WrapPanel Margin="5,0,0,0" Orientation="Horizontal">
                            <wpfui:ProgressRing
                                x:Name="translatedTextLoading"
                                Width="12"
                                Height="12"
                                Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"
                                IsIndeterminate="True" />
                            <Controls:TextBlock x:Name="translatedText" TextWrapping="Wrap" />

                        </WrapPanel>
                    </Controls:DynamicScrollViewer>
                </Grid>
            </Controls:Card>
        </Grid>

        <Controls:SnackbarPresenter
            x:Name="snackbarHost"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom" />

    </Grid>
</Controls:FluentWindow>
