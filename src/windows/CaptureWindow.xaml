<Controls:FluentWindow
    x:Class="ScreenLookup.src.windows.CaptureWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScreenLookup.src.windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:xControls="clr-namespace:ScreenLookup.src.controls"
    x:Name="captureWindow"
    Title="Capture"
    MinHeight="0"
    Background="Transparent"
    Deactivated="App_Deactivated"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Topmost="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid Margin="10,5,10,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="configSection">
            <wpfui:DynamicScrollViewer Padding="15">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="sourceLanguageConfig" SelectionChanged="SourceLanguageConfig_SelectionChanged" />
                        <Controls:SymbolIcon Grid.Column="1" Symbol="ChevronRight24" />
                        <ComboBox
                            x:Name="targetLanguageConfig"
                            Grid.Column="2"
                            SelectionChanged="TargetLanguageConfig_SelectionChanged" />
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Controls:TextBlock Text="Source Language Correction (Hunspell)" />
                        <Controls:ToggleSwitch
                            x:Name="hunSpell"
                            Grid.Column="1"
                            Click="ToggleSwitch_Click"
                            IsChecked="{Binding HunSpell}" />
                    </Grid>

                    <Controls:Button
                        Margin="0,10,0,0"
                        Click="Button_Click"
                        Content="Submit" />
                </StackPanel>
            </wpfui:DynamicScrollViewer>
        </Grid>

        <Grid x:Name="resultSection" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Controls:Card
                x:Name="captureCard"
                Grid.Row="0"
                Padding="0">
                <Controls:Image
                    x:Name="captureImage"
                    Source="/src/images/applicationIcon.ico"
                    Stretch="None" />
            </Controls:Card>

            <Controls:Card
                x:Name="ocrCard"
                Grid.Row="1"
                Margin="0,3,0,0">
                <Controls:DynamicScrollViewer IsScrollingVertically="True" VerticalScrollBarVisibility="Visible">
                    <Controls:TextBlock
                        x:Name="ocrText"
                        Grid.Column="1"
                        Margin="45,0,0,0"
                        Text="ocrText"
                        TextWrapping="Wrap" />
                </Controls:DynamicScrollViewer>
            </Controls:Card>

            <Controls:Card
                x:Name="originalCard"
                Grid.Row="2"
                Margin="0,3,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Controls:Button
                        x:Name="originalTTS"
                        Width="20"
                        Height="20"
                        Padding="0"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_OriginalTTS"
                        Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                Filled=False}" />
                    <Controls:Button
                        Grid.Column="1"
                        Width="{Binding Width, ElementName=originalTTS}"
                        Height="{Binding Height, ElementName=originalTTS}"
                        Margin="2,0,0,0"
                        Padding="0"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_Copy"
                        Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                Filled=False}"
                        Tag="{Binding Text, ElementName=ocrText}"
                        ToolTip="Copy" />
                    <Controls:DynamicScrollViewer
                        x:Name="originalScrollView"
                        Grid.Column="2"
                        IsScrollingVertically="True"
                        VerticalScrollBarVisibility="Visible">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <wpfui:ProgressRing
                                x:Name="originalWordsLoading"
                                Width="12"
                                Height="12"
                                Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"
                                IsIndeterminate="True" />

                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <ItemsControl Name="originalWords">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Controls:Button
                                                Width="{Binding Width}"
                                                Height="{Binding Height}"
                                                Margin="0"
                                                Padding="{Binding Padding}"
                                                HorizontalAlignment="Left"
                                                Background="{wpfui:ThemeResource CardBackgroundFillColorDefault}"
                                                BorderThickness="{Binding Border}"
                                                Click="Button_Word"
                                                Tag="{Binding SourceLanguage}"
                                                ToolTip="{Binding Word}">
                                                <Controls:Button.Content>
                                                    <wpfui:TextBlock
                                                        FontFamily="{Binding FontFace}"
                                                        FontSize="{Binding FontSizeS, Mode=OneWay}"
                                                        Text="{Binding Word}" />
                                                </Controls:Button.Content>
                                            </Controls:Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Controls:DynamicScrollViewer>
                </Grid>
            </Controls:Card>

            <Controls:Card
                x:Name="translatedCard"
                Grid.Row="3"
                Margin="0,3,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Controls:Button
                        x:Name="translatedTSS"
                        Width="20"
                        Height="20"
                        Padding="0"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_TranslatedTTS"
                        Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                Filled=False}" />
                    <Controls:Button
                        Grid.Column="1"
                        Width="{Binding Width, ElementName=translatedTSS}"
                        Height="{Binding Height, ElementName=translatedTSS}"
                        Margin="2,0,0,0"
                        Padding="0"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_Copy"
                        Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                Filled=False}"
                        Tag="{Binding Text, ElementName=translatedText}"
                        ToolTip="Copy" />
                    <Controls:DynamicScrollViewer
                        x:Name="translatedScrollViewer"
                        Grid.Column="2"
                        IsScrollingVertically="True"
                        VerticalScrollBarVisibility="Visible">
                        <WrapPanel Orientation="Horizontal">
                            <Controls:TextBlock
                                x:Name="translatedText"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                TextWrapping="Wrap" />
                            <wpfui:ProgressRing
                                x:Name="translatedTextLoading"
                                Width="12"
                                Height="12"
                                Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"
                                IsIndeterminate="True" />
                        </WrapPanel>
                    </Controls:DynamicScrollViewer>
                </Grid>
            </Controls:Card>

            <Controls:Flyout
                x:Name="flayOut"
                Padding="0"
                Placement="Top">
                <Controls:Flyout.RenderTransform>
                    <MatrixTransform x:Name="mt" />
                </Controls:Flyout.RenderTransform>
                <StackPanel>
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <Controls:Button
                            x:Name="flayoutOriginalTSS"
                            Width="20"
                            Height="20"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="Button_WordOriginalTTS"
                            Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                    Filled=False}" />
                        <Controls:Button
                            Width="{Binding Width, ElementName=flayoutOriginalTSS}"
                            Height="{Binding Height, ElementName=flayoutOriginalTSS}"
                            Margin="2,0,0,0"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="Button_Copy"
                            Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                    Filled=False}"
                            Tag="{Binding Text, ElementName=definitionOriginal}"
                            ToolTip="Copy" />

                        <Controls:TextBlock
                            x:Name="definitionOriginal"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="definitionOriginal" />
                    </StackPanel>
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <Controls:Button
                            x:Name="flayoutTranslatedTSS"
                            Width="20"
                            Height="20"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="Button_WordTranslatedTTS"
                            Icon="{wpfui:SymbolIcon Symbol=Speaker216,
                                                    Filled=False}" />
                        <Controls:Button
                            Width="{Binding Width, ElementName=flayoutTranslatedTSS}"
                            Height="{Binding Height, ElementName=flayoutTranslatedTSS}"
                            Margin="2,0,0,0"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="Button_Copy"
                            Icon="{wpfui:SymbolIcon Symbol=Copy24,
                                                    Filled=False}"
                            Tag="{Binding Text, ElementName=definitionTranslated}"
                            ToolTip="Copy" />
                        <Controls:TextBlock
                            x:Name="definitionTranslated"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                        <wpfui:ProgressRing
                            x:Name="definitionTranslatedLoading"
                            Width="12"
                            Height="12"
                            Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"
                            IsIndeterminate="True" />
                    </StackPanel>
                    <Controls:Card
                        Margin="0,10,0,0"
                        Padding="5"
                        BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Controls:Button
                                x:Name="openBrowser"
                                Width="20"
                                Height="20"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="Button_OpenBrowser"
                                Icon="{wpfui:SymbolIcon Symbol=Globe24,
                                                        Filled=False}" />
                            <Controls:Button
                                x:Name="wordSave"
                                Width="20"
                                Height="20"
                                Margin="2,0,0,0"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="Button_WordSave"
                                Icon="{wpfui:SymbolIcon Symbol=Star24,
                                                        Filled=False}" />
                        </StackPanel>
                    </Controls:Card>
                </StackPanel>
            </Controls:Flyout>
        </Grid>

        <Controls:SnackbarPresenter x:Name="snackbarHost" Grid.Row="2" />

    </Grid>
</Controls:FluentWindow>
