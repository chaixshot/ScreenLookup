<Window x:Class="ScreenTranslator.src.windows.CaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScreenTranslator.src.windows"
        mc:Ignorable="d"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Capture"
        
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        SizeToContent="Height"
        
        Deactivated="App_Deactivated"
        >

    <Grid x:Name="mainWindow">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0">
            <Border
                BorderThickness="1"
                BorderBrush="#FF5B5B5B"
                CornerRadius="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Grid>
                    <!-- Rounded mask (stretches to fill Grid) -->
                    <Border Name="mask" Background="White" CornerRadius="3"/>
                    <!-- Main content container -->
                    <StackPanel>
                        <!-- Use a VisualBrush of 'mask' as the opacity mask -->
                        <StackPanel.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=mask}"/>
                        </StackPanel.OpacityMask>
                        <!-- Any content -->
                        <ui:Image x:Name="captureImage" Stretch="None"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ui:Card>

        <ui:Card Grid.Row="1">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button
                    Grid.Column="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="Button_OriginalTTS"
                    Icon="{ui:SymbolIcon Speaker228,
                        Filled=True}" VerticalAlignment="Top"/>
                <ui:TextBlock x:Name="ocrText" TextWrapping="Wrap" Text="ocrText" Grid.Column="1" Margin="5,0,0,0"/>

            </Grid>
        </ui:Card>

        <ui:Card Grid.Row="2">
            <StackPanel>
                <ItemsControl Name="ocrWords">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Button Content="{Binding Word}" HorizontalAlignment="Left" Click="Button_Word" Margin="0,0,0,0" Padding="1.7,0,1.7,0" >
                            </ui:Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ui:Card>

        <ui:Card Grid.Row="3" >
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:Button
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_WordOriginalTTS"
                        Icon="{ui:SymbolIcon Speaker228,
                            Filled=True}" VerticalAlignment="Top"/>
                    <ui:TextBlock x:Name="definition_original" Text="11111" Margin="5,0,0,0" />


                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:Button
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         Click="Button_WordTranslatedTTS"
                         Icon="{ui:SymbolIcon Speaker228,
                             Filled=True}" VerticalAlignment="Top"/>
                    <ui:TextBlock x:Name="definition_translated" Text="222222" Margin="5,0,0,0" />

                </StackPanel>
            </StackPanel>
        </ui:Card>

        <ui:Card Grid.Row="4">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:Button
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="Button_TranslatedTTS"
                    Icon="{ui:SymbolIcon Speaker228,
                        Filled=True}" VerticalAlignment="Top"/>
                <ui:TextBlock x:Name="translatedText" TextWrapping="Wrap" Text="translatedText" VerticalAlignment="Center" Grid.Column="1" Margin="5,0,0,0"/>
            </Grid>
        </ui:Card>

    </Grid>
</Window>
