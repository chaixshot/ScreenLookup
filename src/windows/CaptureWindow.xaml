<wpfui:FluentWindow x:Name="captureWindow" 
    x:Class="ScreenLookup.src.windows.CaptureWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ScreenLookup.src.windows"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:xControls="clr-namespace:ScreenLookup.src.controls"
    mc:Ignorable="d"
    Title="Capture"
        
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    Deactivated="App_Deactivated"
    MinHeight="0"
    ResizeMode="NoResize"
    >
    <Grid Margin="10,5,10,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <wpfui:Card x:Name="captureImageCard" Grid.Row="0" Padding="0">
            <wpfui:Image x:Name="captureImage" Stretch="None" Source="/applicationIcon.ico"/>
        </wpfui:Card>

        <wpfui:Card x:Name="originalTextCard" Grid.Row="1" Margin="0,3,0,0">
            <wpfui:DynamicScrollViewer IsScrollingVertically="True" VerticalScrollBarVisibility="Visible">
                <wpfui:TextBlock x:Name="originalText" TextWrapping="Wrap" Text="originalText" Grid.Column="1" Margin="45,0,0,0"/>
            </wpfui:DynamicScrollViewer>
        </wpfui:Card>

        <wpfui:Card x:Name="originalWords" Grid.Row="2" Margin="0,3,0,0">
            <wpfui:DynamicScrollViewer IsScrollingVertically="True" VerticalScrollBarVisibility="Visible">
                <Grid >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <wpfui:Button x:Name="originalTTS"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_OriginalTTS"
                        Icon="{wpfui:SymbolIcon Speaker220, Filled=True}"
                        VerticalAlignment="Top"
                        Width="20" Height="20" Padding="0"/>
                    
                    <xControls:LoadingSpiner x:Name="ocrWordsLoading" Width="20" Height="20" Grid.Column="1" Margin="5,0,0,0"/>

                    <StackPanel Grid.Column="2" Margin="5,0,0,0">
                        <ItemsControl Name="ocrWords">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <wpfui:Button
                                        BorderThickness="{Binding Border}"
                                        HorizontalAlignment="Left"
                                        Click="Button_Word"
                                        Margin="0"
                                        Padding="1.5,0,1.5,0"
                                        Width="{Binding Width}" 
                                        Height="{Binding Height}" Tag="{Binding Word}"
                                        >
                                        <wpfui:Button.Content>
                                            <TextBlock
                                                Margin="1.5,0,1.5,0"
                                                Text="{Binding Word}"
                                                FontSize="{Binding FontSizeS, Mode=OneWay}"
                                                FontFamily="{Binding FontFace}"/>
                                        </wpfui:Button.Content>
                                    </wpfui:Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </wpfui:DynamicScrollViewer>
        </wpfui:Card>

        <wpfui:Card x:Name="translatedCard" Grid.Row="3" Margin="0,3,0,0">
            <wpfui:DynamicScrollViewer IsScrollingVertically="True" VerticalScrollBarVisibility="Visible" >
                <StackPanel Orientation="Horizontal">
                    <wpfui:Button x:Name="translatedTSS"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_TranslatedTTS"
                        Icon="{wpfui:SymbolIcon Speaker220, Filled=True}"
                        VerticalAlignment="Top" Width="20" Height="20" Padding="0"/>
                    <wpfui:TextBlock x:Name="translatedText" TextWrapping="Wrap" Grid.Column="1" Margin="5,0,0,0" />
                    <xControls:LoadingSpiner x:Name="translatedTextLoading" Width="20" Height="20"/>
                </StackPanel>
            </wpfui:DynamicScrollViewer>
        </wpfui:Card>

        <wpfui:Flyout
            x:Name="flayOut"
            Padding="0"
            IsOpen="{Binding IsFlyOutOpen, Mode=OneWay}"
            Placement="Top">
            <wpfui:Flyout.RenderTransform>
                <MatrixTransform x:Name="mt"/>
            </wpfui:Flyout.RenderTransform>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <wpfui:Button x:Name="flayoutOriginalTSS"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_WordOriginalTTS"
                        Icon="{wpfui:SymbolIcon Speaker220, Filled=True}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="20" Height="20" Padding="0"/>
                    <wpfui:TextBlock x:Name="definitionOriginal" Text="definitionOriginal" Margin="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <wpfui:Button x:Name="flayoutTranslatedTSS"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="Button_WordTranslatedTTS"
                        Icon="{wpfui:SymbolIcon Speaker220, Filled=True}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="20" Height="20" Padding="0"/>
                    <wpfui:TextBlock x:Name="definitionTranslated" Margin="5,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <xControls:LoadingSpiner x:Name="definitionTranslatedLoading" Width="20" Height="20"/>
                </StackPanel>
                <wpfui:Card Margin="0,10,0,0" Padding="5" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <wpfui:Button x:Name="openBrowser"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="Button_OpenBrowser"
                            Icon="{wpfui:SymbolIcon Globe24, Filled=False}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="20" Height="20" Padding="0"/>
                        <wpfui:Button x:Name="wordSave"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Icon="{wpfui:SymbolIcon Star24, Filled=False}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="20" Height="20" Padding="0" Margin="5,0,0,0" Click="Button_WordSave"/>
                    </StackPanel>
                </wpfui:Card>
            </StackPanel>
        </wpfui:Flyout>

    </Grid>
</wpfui:FluentWindow>
