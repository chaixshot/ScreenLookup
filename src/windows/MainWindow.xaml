<wpfui:FluentWindow 
    xmlns:Controls="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
    x:Class="ScreenLookup.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ScreenLookup.src.pages"
    xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="MainWindow"
    Height="450"
    Width="800"
    StateChanged="WindowStateChanged"
    MinWidth="800"
    MinHeight="600"
    Background="Transparent"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="Manual"
    WindowStyle="None"
    LocationChanged="MainWindow_BoundsChanged"
    SizeChanged="MainWindow_BoundsChanged"
    >

    <Window.Resources>
        <wpfui:ImageIcon x:Key="AppIcon" Source="applicationIcon.ico" />
        
        <Style x:Key="NavMenuContent" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="MainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <wpfui:TitleBar
                Grid.Row="0"
                Height="27"
                Icon="{StaticResource AppIcon}">
                <wpfui:TitleBar.Header>
                    <wpfui:TextBlock Padding="0" VerticalAlignment="Center" FontSize="12">ScreenLookup</wpfui:TextBlock>
                </wpfui:TitleBar.Header>
                <wpfui:TitleBar.TrailingContent>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <wpfui:Button
                            x:Name="TopmostButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="TopmostButton_Click"
                            Icon="{wpfui:SymbolIcon Pin16,
                            Filled=True}"
                            ToolTip="Always on Top" BorderThickness="0"
                            />
                    </StackPanel>
                </wpfui:TitleBar.TrailingContent>
            </wpfui:TitleBar>

            <wpfui:NavigationView
                x:Name="RootNavigation"
                Grid.Row="1"
                Height="Auto"
                IsBackButtonVisible="Collapsed"
                PaneDisplayMode="LeftFluent">
                <wpfui:NavigationView.MenuItems>
                    <wpfui:NavigationViewItem NavigationCacheMode="Enabled" TargetPageType="{x:Type local:SettingPage}">
                        <wpfui:NavigationViewItem.Content>
                            <TextBlock Style="{StaticResource NavMenuContent}" Text="Setting" />
                        </wpfui:NavigationViewItem.Content>
                        <wpfui:NavigationViewItem.Icon>
                            <wpfui:SymbolIcon Symbol="Settings24" />
                        </wpfui:NavigationViewItem.Icon>
                    </wpfui:NavigationViewItem>

                    <wpfui:NavigationViewItem NavigationCacheMode="Enabled" TargetPageType="{x:Type local:HistoryPage}">
                        <wpfui:NavigationViewItem.Content>
                            <TextBlock Style="{StaticResource NavMenuContent}" Text="History" />
                        </wpfui:NavigationViewItem.Content>
                        <wpfui:NavigationViewItem.Icon>
                            <wpfui:SymbolIcon Symbol="History24" />
                        </wpfui:NavigationViewItem.Icon>
                    </wpfui:NavigationViewItem>

                    <wpfui:NavigationViewItem NavigationCacheMode="Enabled" TargetPageType="{x:Type local:SavedPage}">
                        <wpfui:NavigationViewItem.Content>
                            <TextBlock Style="{StaticResource NavMenuContent}" Text="Saved" />
                        </wpfui:NavigationViewItem.Content>
                        <wpfui:NavigationViewItem.Icon>
                            <wpfui:SymbolIcon Symbol="Star24" />
                        </wpfui:NavigationViewItem.Icon>
                    </wpfui:NavigationViewItem>

                    <wpfui:NavigationViewItem NavigationCacheMode="Enabled" TargetPageType="{x:Type local:InfoPage}">
                        <wpfui:NavigationViewItem.Content>
                            <TextBlock Style="{StaticResource NavMenuContent}" Text="About" />
                        </wpfui:NavigationViewItem.Content>
                        <wpfui:NavigationViewItem.Icon>
                            <wpfui:SymbolIcon Symbol="Info24" />
                        </wpfui:NavigationViewItem.Icon>
                    </wpfui:NavigationViewItem>
                </wpfui:NavigationView.MenuItems>
            </wpfui:NavigationView>
        </Grid>

        <wpfui:SnackbarPresenter x:Name="SnackbarHost" Grid.Row="0" />

        <ContentPresenter
        x:Name="DialogHostContainer"
        MinHeight="167"
        Visibility="Collapsed" />

        <tray:NotifyIcon
            x:Name="NotifyIcon"
            LeftClick="NotifyIcon_LeftClick"
            TooltipText="Text Grab" Icon="/src/windows/applicationIcon.ico">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem
                        Click="SettingsMenuItem_Click"
                        Header="Settings">
                        <MenuItem.Icon>
                            <wpfui:SymbolIcon Symbol="Settings24" />
                        </MenuItem.Icon>
                    </MenuItem>
                    
                    <MenuItem
                        Click="CaptureWindowItem_Click"
                        Header="Capture             Alt+Z">
                        <MenuItem.Icon>
                            <wpfui:SymbolIcon Symbol="Screenshot20" />
                        </MenuItem.Icon>
                    </MenuItem>
                    
                    <MenuItem
                        Click="Exit_Click"
                        Header="Close">
                        <MenuItem.Icon>
                            <wpfui:SymbolIcon Symbol="Dismiss24" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</wpfui:FluentWindow>
