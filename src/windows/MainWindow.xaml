<wpfui:FluentWindow 
    xmlns:Controls="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
    x:Class="ScreenLookup.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ScreenLookup.src.pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml/tray"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="MainWindow"
    Height="450"
    Width="800"
    StateChanged="WindowStateChanged"
    MinWidth="800"
    MinHeight="600"
    Background="Transparent"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="Manual"
    WindowStyle="None"
    LocationChanged="MainWindow_BoundsChanged"
    SizeChanged="MainWindow_BoundsChanged"
    >

    <Window.Resources>
        <Style x:Key="NavMenuContent" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="MainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <wpfui:TitleBar
                Grid.Row="0"
                Height="27">
                <wpfui:TitleBar.Header>
                    <wpfui:TextBlock Padding="15,0,0,0" VerticalAlignment="Center">ScreenLookup</wpfui:TextBlock>
                </wpfui:TitleBar.Header>
            </wpfui:TitleBar>

            <wpfui:NavigationView
                x:Name="RootNavigation"
                Grid.Row="1"
                Height="Auto"
                IsBackButtonVisible="Collapsed"
                PaneDisplayMode="LeftFluent">
                <wpfui:NavigationView.MenuItems>
                    <wpfui:NavigationViewItem NavigationCacheMode="Enabled" TargetPageType="{x:Type local:SettingPage}">
                        <wpfui:NavigationViewItem.Content>
                            <TextBlock Style="{StaticResource NavMenuContent}" Text="Setting" />
                        </wpfui:NavigationViewItem.Content>
                        <wpfui:NavigationViewItem.Icon>
                            <wpfui:SymbolIcon Symbol="Settings24" />
                        </wpfui:NavigationViewItem.Icon>
                    </wpfui:NavigationViewItem>

                    <wpfui:NavigationViewItem NavigationCacheMode="Enabled" TargetPageType="{x:Type local:InfoPage}">
                        <wpfui:NavigationViewItem.Content>
                            <TextBlock Style="{StaticResource NavMenuContent}" Text="About" />
                        </wpfui:NavigationViewItem.Content>
                        <wpfui:NavigationViewItem.Icon>
                            <wpfui:SymbolIcon Symbol="Info24" />
                        </wpfui:NavigationViewItem.Icon>
                    </wpfui:NavigationViewItem>
                </wpfui:NavigationView.MenuItems>
            </wpfui:NavigationView>
        </Grid>

        <wpfui:SnackbarPresenter x:Name="SnackbarHost" Grid.Row="0" />

        <ContentPresenter
        x:Name="DialogHostContainer"
        MinHeight="167"
        Visibility="Collapsed" />

        <ui:NotifyIcon
            x:Name="NotifyIcon"
            IsVisibleChanged="NotifyIcon_IsVisibleChanged"
            LeftClick="NotifyIcon_LeftClick"
            TooltipText="Text Grab" Icon="/src/windows/applicationIcon.ico">
            <ui:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem
                        Click="SettingsMenuItem_Click"
                        Header="Settings">
                        <MenuItem.Icon>
                            <wpfui:SymbolIcon Symbol="Settings24" />
                        </MenuItem.Icon>
                    </MenuItem>
                    
                    <MenuItem
                        Click="CaptureWindowItem_Click"
                        Header="Edit Text Window">
                        <MenuItem.Icon>
                            <wpfui:SymbolIcon Symbol="Screenshot20" />
                        </MenuItem.Icon>
                    </MenuItem>
                    
                    <MenuItem
                        Click="Exit_Click"
                        Header="Close Text Grab">
                        <MenuItem.Icon>
                            <wpfui:SymbolIcon Symbol="Dismiss24" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ui:NotifyIcon.Menu>
        </ui:NotifyIcon>
    </Grid>
</wpfui:FluentWindow>
